        "scriptLang" : "JS",
        "jsScript" : "var floor = metadata.floorName;\r\nvar newMsg = {};\r\n\r\nfunction safeParse(jsonStr) {\r\n    var obj = {};\r\n    if (jsonStr) {\r\n        try {\r\n            var parsed = JSON.parse(jsonStr);\r\n            while (typeof parsed === 'string') { parsed = JSON.parse(parsed); }\r\n            if (typeof parsed === 'object' && parsed !== null) { obj = parsed; }\r\n        } catch(e) {}\r\n    }\r\n    return obj;\r\n}\r\n\r\nvar powerState = safeParse(metadata.floors_power_state);\r\nvar energyState = safeParse(metadata.floors_energy_state);\r\n\r\n// 1. รวม Power ของทุกชั้นในตึก\r\nif (msg.power_total_floor !== undefined && msg.power_total_floor !== null && msg.power_total_floor !== \"\") {\r\n    powerState[floor] = Number(msg.power_total_floor) || 0;\r\n    var totalPower = 0;\r\n    for (var f in powerState) { totalPower += Number(powerState[f]) || 0; }\r\n    newMsg.floors_power_state = JSON.stringify(powerState);\r\n    newMsg.power_total_building = totalPower;\r\n}\r\n\r\n// 2. รวม Energy สะสมของทุกชั้นในตึก\r\nif (msg.energy_kwh_floor !== undefined && msg.energy_kwh_floor !== null && msg.energy_kwh_floor !== \"\") {\r\n    energyState[floor] = Number(msg.energy_kwh_floor) || 0;\r\n    var totalEnergy = 0;\r\n    for (var f in energyState) { totalEnergy += Number(energyState[f]) || 0; }\r\n    newMsg.floors_energy_state = JSON.stringify(energyState);\r\n    newMsg.energy_kwh_building = totalEnergy;\r\n}\r\n\r\n// 3. โยนค่า Consumption และ CO2 เข้ากระปุกของตึกตรงๆ เลย!\r\nif (msg.Energy_consumption !== undefined && msg.Energy_consumption !== null) {\r\n    newMsg.Energy_consumption = Number(msg.Energy_consumption);\r\n    if (msg.CO2 !== undefined && msg.CO2 !== null) {\r\n        newMsg.CO2 = Number(msg.CO2);\r\n    }\r\n}\r\n\r\nreturn {msg: newMsg, metadata: metadata, msgType: msgType};",
        "tbelScript" : "// 1. ดึงข้อมูลสถานะล่าสุดของมิเตอร์ทุกตัวในชั้น (จากที่ดึงมาในขั้นที่ 2)\r\nvar state = {};\r\nif (metadata.meters_state_json) {\r\n    try { \r\n        state = JSON.parse(metadata.meters_state_json); \r\n    } catch(e) {}\r\n}\r\n\r\n// 2. อัปเดตข้อมูลเฉพาะมิเตอร์ตัวที่เพิ่งส่งข้อมูลเข้ามา (ระบบดึง Device Name ให้อัตโนมัติ)\r\nstate[metadata.deviceName] = {\r\n    power: parseFloat(msg.power_total) || 0,\r\n    energy: parseFloat(msg.energy_kWh) || 0\r\n};\r\n\r\n// 3. วนลูปคำนวณผลรวมพลังงานของมิเตอร์ \"ทุกตัว\" ในชั้นนี้\r\nvar totalPower = 0;\r\nvar totalEnergy = 0;\r\nfor (var meter in state) {\r\n    totalPower += state[meter].power;\r\n    totalEnergy += state[meter].energy;\r\n}\r\n\r\n// 5. สร้าง Message ใหม่เพื่อบันทึกผลลัพธ์\r\nvar newMsg = {\r\n    meters_state_json: JSON.stringify(state), // ซ่อนค่าแยกมิเตอร์ไว้ในตัวแปรนี้เพื่อใช้คำนวณรอบหน้า\r\n    power_total_floor: totalPower,\r\n    energy_kWh_floor: totalEnergy,\r\n};\r\n\r\nreturn {msg: newMsg, metadata: metadata, msgType: msgType};"
