      "configuration" : {
        "scriptLang" : "JS",
        "jsScript" : "// เช็คว่ามีตัวแปรส่งมาจริง และค่าต้องไม่ใช่ null และไม่ใช่ข้อความว่าง \"\"\r\nvar hasPower = msg.hasOwnProperty('power_total') && msg.power_total !== null && msg.power_total !== \"\";\r\nvar hasEnergy = msg.hasOwnProperty('energy_kwh') && msg.energy_kwh !== null && msg.energy_kwh !== \"\";\r\n\r\nreturn hasPower || hasEnergy;",
